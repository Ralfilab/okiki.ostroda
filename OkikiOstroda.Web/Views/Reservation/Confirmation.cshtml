@model OkikiOstroda.Web.Models.Reservation
@{
    ViewData["Title"] = T["ReservationConfirmationTitle"];
}

<section class="page-hero compact">
    <div class="container">
        <p class="eyebrow">@T["ReservationTransferTitleValue", Model.Id, Model.GuestName]</p>
        <h1>@T["ReservationConfirmationHeading"]</h1>
    </div>
</section>

<section class="section">
    <div class="container narrow">
        <div class="contact-card">
            <p>@T["ReservationNumber"] <strong>#@Model.Id</strong></p>
            <p>@T["ReservationDateRange"] <strong>@Model.StartDate.ToString("yyyy-MM-dd") – @Model.EndDate.ToString("yyyy-MM-dd")</strong></p>
            <p>@T["ReservationPrice"] <strong>@Model.TotalPrice.ToString("0.00") PLN</strong></p>
            <hr />
            <h2>@T["ReservationPaymentDetails"]</h2>
            <p>@T["ReservationAccountNumber"] <strong>52 1020 1127 0000 1602 0391 3597</strong></p>
            <p>@T["ReservationTransferTitle"] <strong>@T["ReservationTransferTitleValue", Model.Id, Model.GuestName]</strong></p>
            <p>@T["ReservationConfirmationEmailSent"]</p>
        </div>
    </div>
</section>
