@model OkikiOstroda.Web.Models.ReservationRequest
@using OkikiOstroda.Web.Models
@using Microsoft.Extensions.Options
@using System.Text.Json
@inject IOptions<PricingOptions> PricingOptions
@{
    ViewData["Title"] = T["ReservationTitle"];
    ViewData["Description"] = T["ReservationDescription"];
    var pricing = PricingOptions.Value;
    var reservations = (IEnumerable<dynamic>)(ViewBag.Reservations ?? Enumerable.Empty<object>());
    var bookedRanges = reservations
        .Select(x => new
        {
            from = x.StartDate.ToString("yyyy-MM-dd"),
            to = x.EndDate.AddDays(-1).ToString("yyyy-MM-dd")
        });
    var bookedRangesJson = JsonSerializer.Serialize(bookedRanges);
}

<section class="page-hero compact">
    <div class="container">
        <p class="eyebrow">@T["ReservationEyebrow"]</p>
        <h1>@T["ReservationHeading"]</h1>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-6">
                <div class="availability-calendar-card">
                    <h2>@T["ReservationCalendarHeading"]</h2>
                    <p class="text-muted mb-4">@T["ReservationCalendarDescription"]</p>
                    <div id="availability-calendar" data-booked-ranges='@Html.Raw(bookedRangesJson)'></div>
                    <div class="availability-legend mt-4">
                        <span><i class="available"></i>@T["ReservationAvailable"]</span>
                        <span><i class="booked"></i>@T["ReservationBooked"]</span>
                    </div>
                </div>
                <div class="price-grid price-grid-single mt-4">
                    <div><strong>@T["ReservationPriceFirstNights"]</strong><span><strong>@T["ReservationPriceFromThirdNight"]</strong></span><small>@T["ReservationPriceMinimumStayLowPeak"]</small><br /><small>@T["ReservationPriceMinimumStayHighPeak"]</small></div>
                </div>
            </div>
            <div class="col-lg-6">
                <form asp-action="Index" method="post" class="booking-form">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <input asp-for="StartDate" type="hidden" />
                    <input asp-for="EndDate" type="hidden" />
                    <div class="row g-3">
                        <div class="col-12"><label asp-for="GuestName" class="form-label">@T["ReservationGuestName"]</label><input asp-for="GuestName" class="form-control" /><span asp-validation-for="GuestName" class="text-danger"></span></div>
                        <div class="col-sm-6"><label asp-for="GuestEmail" class="form-label">Email</label><input asp-for="GuestEmail" class="form-control" /><span asp-validation-for="GuestEmail" class="text-danger"></span></div>
                        <div class="col-sm-6"><label asp-for="GuestPhone" class="form-label">@T["Phone"]</label><input asp-for="GuestPhone" class="form-control" /><span asp-validation-for="GuestPhone" class="text-danger"></span></div>
                        <div class="col-12"><label asp-for="GuestAddressStreet" class="form-label">@T["ReservationGuestAddressStreet"]</label><input asp-for="GuestAddressStreet" class="form-control" /><span asp-validation-for="GuestAddressStreet" class="text-danger"></span></div>
                        <div class="col-sm-6"><label asp-for="GuestAddressTown" class="form-label">@T["ReservationGuestAddressTown"]</label><input asp-for="GuestAddressTown" class="form-control" /><span asp-validation-for="GuestAddressTown" class="text-danger"></span></div>
                        <div class="col-sm-6"><label asp-for="GuestAddressPostCode" class="form-label">@T["ReservationGuestAddressPostCode"]</label><input asp-for="GuestAddressPostCode" class="form-control" /><span asp-validation-for="GuestAddressPostCode" class="text-danger"></span></div>
                        <div class="col-12"><label asp-for="Guests" class="form-label">@T["ReservationGuests"]</label><input asp-for="Guests" type="number" min="1" max="2" class="form-control" /><span asp-validation-for="Guests" class="text-danger"></span></div>
                        <div class="col-12"><label asp-for="Notes" class="form-label">@T["ReservationMessage"]</label><textarea asp-for="Notes" class="form-control" rows="4"></textarea></div>
                        <div class="col-12">
                            <div id="price-calculation" class="alert alert-light border mb-0"
                                 data-base-rate="@pricing.HighSeasonDailyRate.ToString("0")"
                                 data-discount-rate="@pricing.DiscountedDailyRate.ToString("0")"
                                 data-discount-starts-after="@pricing.DiscountStartsAfterNights"
                                 data-empty-message="@T["ReservationPricePrompt"]"
                                 data-currency-suffix="@T["ReservationPriceCurrencySuffix"]">
                                @T["ReservationPricePrompt"]
                            </div>
                        </div>
                    </div>
                    <button class="btn btn-dark btn-lg rounded-pill px-5 mt-4" type="submit">@T["ReservationSubmit"]</button>
                </form>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr/dist/l10n/pl.js"></script>
}
