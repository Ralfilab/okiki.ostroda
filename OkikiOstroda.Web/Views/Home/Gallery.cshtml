@{
    ViewData["Title"] = T["GalleryTitle"];
    ViewData["Description"] = T["GalleryDescription"];
    var images = Enumerable.Range(6623, 71)
        .Where(x => x is not 6626 and not 6640 and not 6642 and not 6643 and not 6661 and not 6678 and not 6679 and not 6680 and not 6684 and not 6688 and not 6692)
        .Select(x => $"IMG_{x}.JPEG");
}

<section class="page-hero compact">
    <div class="container">
        <p class="eyebrow">@T["GalleryTitle"]</p>
        <h1>@T["GalleryHeading"]</h1>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="gallery-grid">
            @foreach (var image in images)
            {
                <a href="~/images/@image" target="_blank"><img src="~/images/@image" alt="@T["GalleryAlt"]" loading="lazy" /></a>
            }
        </div>
    </div>
</section>
