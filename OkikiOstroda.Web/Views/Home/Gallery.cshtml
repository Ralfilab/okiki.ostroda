@{
    ViewData["Title"] = T["GalleryTitle"];
    ViewData["Description"] = T["GalleryDescription"];
    var images = new[]
    {
        "bedroom_1.jpg",
        "bedroom_wardrobe.jpg",
        "bedroom_windows.jpg",
        "fire_place.jpg",
        "hot_tub.jpg",
        "house.jpg",
        "living_room_router.jpg",
        "living_room_sunset_view.jpg",
        "living_room_table.jpg",
        "patio.jpg",
        "shower.jpg",
        "sink.jpg"
    };
}

<section class="page-hero compact">
    <div class="container">
        <p class="eyebrow">@T["GalleryTitle"]</p>
        <h1>@T["GalleryHeading"]</h1>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="gallery-grid">
            @foreach (var image in images)
            {
                <a href="~/images/@image" target="_blank"><img src="~/images/@image" alt="@T["GalleryAlt"]" loading="lazy" /></a>
            }
        </div>
    </div>
</section>
