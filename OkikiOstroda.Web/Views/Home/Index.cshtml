@{
    ViewData["Title"] = T["HomeTitle"];
    ViewData["Description"] = T["HomeDescription"];
}

<section class="hero">
    <div class="hero-overlay"></div>
    <div class="container hero-content">
        <p class="eyebrow">@T["HomeHeroEyebrow"]</p>
        <h1>@T["HomeHeroHeading"]</h1>
        <p class="lead">@T["HomeHeroLead"]</p>
        <a class="btn btn-light btn-lg rounded-pill px-5" asp-controller="Reservation" asp-action="Index">@T["HomeHeroButton"]</a>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <p class="eyebrow">@T["HomeIntroEyebrow"]</p>
                <h2>@T["HomeIntroHeading"]</h2>
            </div>
            <div class="col-lg-6">
                <p>@T["HomeIntroBody"]</p>
            </div>
        </div>
        <div class="feature-grid mt-5">
            <div><strong>@T["HomeFeatureGuests"]</strong><span>@T["HomeFeatureGuestsLabel"]</span></div>
            <div><strong>Jacuzzi</strong><span>@T["HomeFeatureHotTubLabel"]</span></div>
            <div><strong>AC</strong><span>@T["AmenityAirConditioning"]</span></div>
            <div><strong>@T["HomeFeatureKitchen"]</strong><span>@T["HomeFeatureKitchenLabel"]</span></div>
        </div>
    </div>
</section>
