@{
    ViewData["Title"] = "Okolica";
    ViewData["Description"] = "Okiki Ostroda znajduje się w Boguszewie, 14-140, w spokojnej okolicy blisko natury.";
}

<section class="page-hero compact">
    <div class="container">
        <p class="eyebrow">Boguszewo, 14-140</p>
        <h1>Spokojna lokalizacja blisko Ostródy</h1>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-6">
                <div class="ratio ratio-4x3 rounded overflow-hidden shadow-sm">
                    <iframe src="https://www.google.com/maps?q=Boguszewo%2014-140&output=embed" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                </div>
            </div>
            <div class="col-lg-6">
                <img class="img-fluid rounded shadow-sm" src="~/images/static-map.svg" alt="Mapa dojazdu Okiki Ostroda" />
                <p class="mt-3">Miejsce na statyczną mapę dojazdu. Podmień plik <code>wwwroot/images/static-map.svg</code> na własną grafikę.</p>
            </div>
        </div>
    </div>
</section>
