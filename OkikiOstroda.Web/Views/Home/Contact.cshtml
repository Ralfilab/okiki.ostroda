@{
    ViewData["Title"] = T["ContactTitle"];
    ViewData["Description"] = T["ContactDescription"];
}

<section class="page-hero compact">
    <div class="container">
        <p class="eyebrow">@T["ContactEyebrow"]</p>
        <h1>@T["ContactTitle"]</h1>
    </div>
</section>

<section class="section">
    <div class="container narrow">
        <div class="contact-card">
            <h2>Okiki Ostroda</h2>
            <p>Boguszewo, 14-140</p>
            <p><a href="tel:+48730249084">+48 730 249 084</a></p>
            <p>@T["ContactEmailSoon"]</p>
            <a class="btn btn-dark rounded-pill px-4" asp-controller="Reservation" asp-action="Index">@T["ContactButton"]</a>
        </div>
    </div>
</section>
