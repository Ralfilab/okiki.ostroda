@{
    ViewData["Title"] = T["PropertyTitle"];
    ViewData["Description"] = T["PropertyDescription"];
}

<section class="page-hero compact">
    <div class="container">
        <p class="eyebrow">@T["NavHome"]</p>
        <h1>@T["PropertyHeading"]</h1>
    </div>
</section>

<section class="section">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-5">
                <h2>@T["PropertyIntroHeading"]</h2>
                <p>@T["PropertyIntroBody"]</p>
            </div>
            <div class="col-lg-7">
                <div class="amenity-grid">
                    <div>@T["AmenityAirConditioning"]</div>
                    <div>@T["AmenityHotTub"]</div>
                    <div>@T["AmenityKettle"]</div>
                    <div>@T["AmenityCoffeeMachine"]</div>
                    <div>@T["AmenityFullKitchen"]</div>
                    <div>@T["AmenityForChildren"]</div>
                </div>
            </div>
        </div>
    </div>
</section>
