@model IEnumerable<OkikiOstroda.Web.Models.Reservation>
@{
    ViewData["Title"] = T["AdminAdministration"];
    var showPast = ViewBag.ShowPast as bool? ?? false;
    var search = ViewBag.Search as string ?? string.Empty;
}

<section class="section top-offset">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>@T["AdminPanel"]</h1>
            <div class="d-flex gap-2">
                <a asp-action="Calendars" class="btn btn-outline-dark">External Calendars</a>
                <form asp-action="Logout" method="post"><button class="btn btn-outline-dark" type="submit">@T["AdminLogout"]</button></form>
            </div>
        </div>

        <form asp-action="Block" method="post" class="booking-form mb-5">
            <h2>@T["AdminBlockDateRange"]</h2>
            <div class="row g-3">
                <div class="col-md-5"><label class="form-label">@T["AdminFrom"]</label><input name="startDate" type="date" class="form-control" required /></div>
                <div class="col-md-5"><label class="form-label">@T["AdminTo"]</label><input name="endDate" type="date" class="form-control" required /></div>
                <div class="col-md-2 d-flex align-items-end"><button class="btn btn-dark w-100" type="submit">@T["AdminAdd"]</button></div>
            </div>
        </form>

        <form asp-action="Index" method="get" class="booking-form mb-4">
            <h2>@T["AdminFilters"]</h2>
            <div class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label" for="search">@T["AdminSearch"]</label>
                    <input id="search" name="search" type="search" class="form-control" value="@search" placeholder="@T["AdminSearchPlaceholder"]" />
                </div>
                <div class="col-md-2">
                    <div class="form-check mb-2">
                        <input id="showPast" name="showPast" type="checkbox" class="form-check-input" value="true" checked="@showPast" />
                        <label class="form-check-label" for="showPast">@T["AdminShowPast"]</label>
                    </div>
                </div>
                <div class="col-md-5 d-flex gap-2">
                    <button class="btn btn-dark flex-fill" type="submit">@T["AdminApplyFilters"]</button>
                    <a asp-action="Index" class="btn btn-outline-dark flex-fill">@T["AdminClearFilters"]</a>
                </div>
            </div>
            <div class="form-text mt-2">@(showPast ? T["AdminShowingAllBookings"] : T["AdminShowingUpcomingBookings"])</div>
        </form>

        @foreach (var item in Model)
        {
            <div class="admin-card">
                <div class="admin-card-header">
                    <strong>#@item.Id</strong>
                    <span class="admin-badge @(item.IsPaid ? "admin-badge-confirmed" : "admin-badge-pending")">@(item.IsPaid ? "Paid" : "Unpaid")</span>
                    @if (item.Source != null) { <span class="admin-badge admin-badge-blocked">External</span> }
                </div>
                <div class="row g-3">
                    <div class="col-sm-6 col-md-4">
                        <div class="admin-card-label">@T["AdminGuest"]</div>
                        <div class="admin-card-value">@item.GuestName</div>
                    </div>
                    <div class="col-sm-6 col-md-4">
                        <div class="admin-card-label">Email</div>
                        <div class="admin-card-value">@item.GuestEmail</div>
                    </div>
                    <div class="col-sm-6 col-md-4">
                        <div class="admin-card-label">@T["Phone"]</div>
                        <div class="admin-card-value">@item.GuestPhone</div>
                    </div>
                    <div class="col-sm-6 col-md-4">
                        <div class="admin-card-label">@T["AdminGuests"]</div>
                        <div class="admin-card-value">@item.Guests</div>
                    </div>
                    <div class="col-sm-6 col-md-4">
                        <div class="admin-card-label">@T["ReservationDateRange"]</div>
                        <div class="admin-card-value">@item.StartDate.ToString("dd-MM-yyyy") – @item.EndDate.ToString("dd-MM-yyyy")</div>
                    </div>
                    <div class="col-sm-6 col-md-4">
                        <div class="admin-card-label">@T["ReservationPrice"]</div>
                        <div class="admin-card-value">@item.TotalPrice.ToString("0.00") zł</div>
                    </div>
                    <div class="col-sm-6 col-md-4">
                        <div class="admin-card-label">@T["AdminAddress"]</div>
                        <div class="admin-card-value">@item.GuestAddressStreet, @item.GuestAddressPostCode @item.GuestAddressTown</div>
                    </div>
                    <div class="col-sm-6 col-md-4">
                        <div class="admin-card-label">@T["AdminCreatedAt"]</div>
                        <div class="admin-card-value">@item.CreatedAtUtc.ToString("dd-MM-yyyy HH:mm")</div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(item.Notes))
                    {
                        <div class="col-12">
                            <div class="admin-card-label">@T["AdminNotes"]</div>
                            <div class="admin-card-value">@item.Notes</div>
                        </div>
                    }
                    <div class="col-12">
                        <div class="d-flex gap-2 align-items-center flex-wrap">
                            <form asp-action="SetPaid" method="post" class="d-flex gap-2 align-items-center">
                                <input type="hidden" name="id" value="@item.Id" />
                                <input type="hidden" name="showPast" value="@showPast.ToString().ToLowerInvariant()" />
                                <input type="hidden" name="search" value="@search" />
                                <select name="isPaid" class="form-select form-select-sm" style="max-width:180px;">
                                    <option value="false" selected="@(!item.IsPaid)">Unpaid</option>
                                    <option value="true" selected="@item.IsPaid">Paid</option>
                                </select>
                                <button class="btn btn-sm btn-outline-dark" type="submit">@T["AdminSave"]</button>
                            </form>
                            <form asp-action="Delete" method="post" onsubmit="return confirm('@T["AdminDeleteConfirm"] @item.StartDate.ToString("dd-MM-yyyy") – @item.EndDate.ToString("dd-MM-yyyy")');">                                <input type="hidden" name="id" value="@item.Id" />
                                <input type="hidden" name="showPast" value="@showPast.ToString().ToLowerInvariant()" />
                                <input type="hidden" name="search" value="@search" />
                                <button class="btn btn-sm btn-outline-danger" type="submit">@T["AdminDelete"]</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>
