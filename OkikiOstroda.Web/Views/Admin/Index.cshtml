@model IEnumerable<OkikiOstroda.Web.Models.Reservation>
@using OkikiOstroda.Web.Models
@{
    ViewData["Title"] = T["AdminAdministration"];
}

<section class="section top-offset">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>@T["AdminPanel"]</h1>
            <div class="d-flex gap-2">
                <a asp-action="Calendars" class="btn btn-outline-dark">External Calendars</a>
                <form asp-action="Logout" method="post"><button class="btn btn-outline-dark" type="submit">@T["AdminLogout"]</button></form>
            </div>
        </div>

        <form asp-action="Block" method="post" class="booking-form mb-5">
            <h2>@T["AdminBlockDateRange"]</h2>
            <div class="row g-3">
                <div class="col-md-5"><label class="form-label">@T["AdminFrom"]</label><input name="startDate" type="date" class="form-control" required /></div>
                <div class="col-md-5"><label class="form-label">@T["AdminTo"]</label><input name="endDate" type="date" class="form-control" required /></div>
                <div class="col-md-2 d-flex align-items-end"><button class="btn btn-dark w-100" type="submit">@T["AdminAdd"]</button></div>
            </div>
        </form>

        @foreach (var item in Model)
        {
            var badgeClass = item.Status switch
            {
                ReservationStatus.Pending => "admin-badge-pending",
                ReservationStatus.Confirmed => "admin-badge-confirmed",
                ReservationStatus.Cancelled => "admin-badge-cancelled",
                ReservationStatus.Blocked => "admin-badge-blocked",
                _ => ""
            };
            <div class="admin-card">
                <div class="admin-card-header">
                    <strong>#@item.Id</strong>
                    <span class="admin-badge @badgeClass">@item.Status</span>
                </div>
                <div class="row g-3">
                    <div class="col-sm-6 col-md-4">
                        <div class="admin-card-label">@T["AdminGuest"]</div>
                        <div class="admin-card-value">@item.GuestName</div>
                    </div>
                    <div class="col-sm-6 col-md-4">
                        <div class="admin-card-label">Email</div>
                        <div class="admin-card-value">@item.GuestEmail</div>
                    </div>
                    <div class="col-sm-6 col-md-4">
                        <div class="admin-card-label">@T["Phone"]</div>
                        <div class="admin-card-value">@item.GuestPhone</div>
                    </div>
                    <div class="col-sm-6 col-md-4">
                        <div class="admin-card-label">@T["AdminGuests"]</div>
                        <div class="admin-card-value">@item.Guests</div>
                    </div>
                    <div class="col-sm-6 col-md-4">
                        <div class="admin-card-label">@T["ReservationDateRange"]</div>
                        <div class="admin-card-value">@item.StartDate.ToString("yyyy-MM-dd") – @item.EndDate.ToString("yyyy-MM-dd")</div>
                    </div>
                    <div class="col-sm-6 col-md-4">
                        <div class="admin-card-label">@T["ReservationPrice"]</div>
                        <div class="admin-card-value">@item.TotalPrice.ToString("0.00") zł</div>
                    </div>
                    <div class="col-sm-6 col-md-4">
                        <div class="admin-card-label">@T["AdminAddress"]</div>
                        <div class="admin-card-value">@item.GuestAddressStreet, @item.GuestAddressPostCode @item.GuestAddressTown</div>
                    </div>
                    <div class="col-sm-6 col-md-4">
                        <div class="admin-card-label">@T["AdminCreatedAt"]</div>
                        <div class="admin-card-value">@item.CreatedAtUtc.ToString("yyyy-MM-dd HH:mm")</div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(item.Notes))
                    {
                        <div class="col-12">
                            <div class="admin-card-label">@T["AdminNotes"]</div>
                            <div class="admin-card-value">@item.Notes</div>
                        </div>
                    }
                    <div class="col-12">
                        <div class="d-flex gap-2 align-items-center flex-wrap">
                            <form asp-action="SetStatus" method="post" class="d-flex gap-2 align-items-center">
                                <input type="hidden" name="id" value="@item.Id" />
                                <select name="status" class="form-select form-select-sm" style="max-width:180px;">
                                    @foreach (var status in Enum.GetValues<ReservationStatus>())
                                    {
                                        <option value="@status" selected="@(item.Status == status)">@status</option>
                                    }
                                </select>
                                <button class="btn btn-sm btn-outline-dark" type="submit">@T["AdminSave"]</button>
                            </form>
                            <form asp-action="Delete" method="post" onsubmit="return confirm('@T["AdminDeleteConfirm"] @item.StartDate.ToString("yyyy-MM-dd") – @item.EndDate.ToString("yyyy-MM-dd")');">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button class="btn btn-sm btn-outline-danger" type="submit">@T["AdminDelete"]</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</section>
